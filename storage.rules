rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny ALL reads and writes unless explicitly authorized
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to check if a user is uploading their own user Avatar/Profile
    match /users/{userId}/{allImages=**} {
      allow read: if true; // Public profiles are read-only
      allow write: if isAuthenticated() && request.auth.uid == userId; // Only owner can write
    }

    // Shop Artwork Folders
    // Expecting path structure: /shops/{shopId}/artworks/{artworkId}.png
    match /shops/{shopId}/artworks/{artworkId} {
      // Must be authenticated and assigned to the same shopId
      // In advanced implementations, this requires checking the firestore token
      // For now, restrict write size to prevent abuse
      allow write: if isAuthenticated() &&
                   request.resource.size < 50 * 1024 * 1024 && // Limit to 50MB
                   request.resource.contentType.matches('image/.*'); // Only images
      
      // Anyone with the exact download link can read (For Customer Portal)
      allow read: if true; 
    }

    // Shop Gangsheets
    // Expecting path structure: /shops/{shopId}/gangsheets/{gangsheetId}.png
    match /shops/{shopId}/gangsheets/{gangsheetId} {
      allow write: if isAuthenticated() && 
                   request.resource.size < 200 * 1024 * 1024 && // 200MB limit for big gangsheets
                   request.resource.contentType.matches('image/.*'); 
      
      // Public Read (If shared or viewed on Kanban)
      allow read: if true;
    }

     // Temporary mockups generated by AI (Public Read, Authenticated Write)
    match /mockups/{mockupId} {
      allow write: if isAuthenticated() &&
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
      
      allow read: if true;
    }
  }
}
